{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist/npm",
    "rootDir": "./src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2023"]
  },
  "include": [
    "src/lib/index.ts",
    "src/services/health.ts",
    "src/types/health.ts",
    "src/adapters/provider.ts"
  ]
}
